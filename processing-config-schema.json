{
  "type": "object",
  "layout": "tabs",
  "required": [
    "datasetMode"
  ],
  "allOf": [
    {
      "title": "Jeu de données",
      "default": {
        "datasetMode": "create",
        "datasetTitle": "DECP"
      },
       "oneOf": [
        {
          "title": "Créer un jeu de données",
          "required": ["datasetTitle"],
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "create",
              "title": "Action"
            },
            "datasetTitle": {
              "type": "string",
              "title": "Titre du jeu de données à créer",
              "default": "DECP"
            },
            "initializeDataset": {
              "type": "boolean",
              "title": "Initialiser le jeu de donnée",
              "description": "Récupère tous les decp annuels de data.gouv",
              "default": true
            }
          }
        },
        {
          "title": "Mettre à jour un jeu de données",
          "required": ["dataset"],
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "update"
            },
            "dataset": {
              "type": "object",
              "title": "Jeu de données",
              "properties": {
                "id": {
                  "type": "string",
                  "title": "Identifiant"
                },
                "title": {
                  "type": "string",
                  "title": "Titre"
                }
              },
              "layout": {
                "getItems": {
                  "url": "${context.dataFairUrl}/api/v1/datasets?select=id,title&${context.ownerFilter}&raw=true",
                  "qSearchParam": "q",
                  "itemsResults": "results",
                  "itemTitle": "item.title",
                  "itemKey": "item.id"
                }
              }
            }
          }
        }
      ]
    }
  ]
}