{
  "type": "object",
  "layout": "tabs",
  "required": [
    "datasetMode",
    "url"
  ],
  "allOf": [
    {
      "title": "Jeu de données",
      "default": {
        "datasetMode": "create",
        "dataset": {
          "id": "",
          "title": "DECP"
        }
      },
      "oneOf": [
        {
          "title": "Créer un jeu de données",
          "required": [
            "dataset"
          ],
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "create",
              "title": "Action"
            },
            "dataset": {
              "type": "object",
              "required": [
                "title"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "title": "Titre",
                  "default": "DECP"
                }
              }
            }
          }
        },
        {
          "title": "Mettre à jour un jeu de données",
          "required": [
            "dataset"
          ],
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "update"
            },
            "dataset": {
              "type": "object",
              "title": "Jeu de données",
              "properties": {
                "id": {
                  "type": "string",
                  "title": "Identifiant"
                },
                "title": {
                  "type": "string",
                  "title": "Titre"
                }
              },
              "layout": {
                "getItems": {
                  "url": "${context.dataFairUrl}/api/v1/datasets?select=id,title&${context.ownerFilter}&raw=true",
                  "qSearchParam": "q",
                  "itemsResults": "results",
                  "itemTitle": "item.title",
                  "itemKey": "item.id"
                }
              }
            }
          }
        }
      ]
    },
    {
      "title": "Source des données",
      "properties": {
        "url": {
          "title": "URL source",
          "type": "string",
          "description": "les protocoles supportés sont HTTP et HTTPS"
        }
      }
    }
  ]
}